---
const { name } = Astro.props;

const breadcrumbList = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.titaniumroofingllc.com/" },
    { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://www.titaniumroofingllc.com/locations" },
    { "@type": "ListItem", "position": 3, "name": name, "item": `https://www.titaniumroofingllc.com/locations/${name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}` }
  ]
};

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `Titanium Roofing - ${name}`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": name,
    "addressRegion": "FL",
    "addressCountry": "US"
  },
  "url": `https://www.titaniumroofingllc.com/locations/${name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`,
  "areaServed": {
    "@type": "City",
    "name": `${name}, FL`
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Do I need a permit for roofing in ${name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Most roofing projects in ${name} require local authorization. Check city hall guidelines.`
      }
    },
    {
      "@type": "Question",
      "name": `How long do roofing projects take in ${name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Every project in ${name} is unique, but our experienced local crews work efficiently to minimize disruption.`
      }
    }
  ]
};
---
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbList)} />
<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
