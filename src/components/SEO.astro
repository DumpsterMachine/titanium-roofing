---
const { name } = Astro.props;

const breadcrumbList = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.titaniumroofingllc.com/" },
    { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://www.titaniumroofingllc.com/locations" },
    { "@type": "ListItem", "position": 3, "name": name, "item": `https://www.titaniumroofingllc.com/locations/${name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}` }
  ]
};

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `Titanium Roofing - ${name}`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": name,
    "addressRegion": "FL",
    "addressCountry": "US"
  },
  "url": `https://www.titaniumroofingllc.com/locations/${name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`,
  "areaServed": {
    "@type": "City",
    "name": `${name}, FL`
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Do I need a permit for roofing in ${name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Yes, most residential roofing projects in ${name} require a permit. Titanium Roofing handles the application process for you, ensuring compliance with local ${name} building codes.`
      }
    },
    {
      "@type": "Question",
      "name": `How long does a typical roofing project in ${name} take?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `While every home in ${name} varies, our local crews typically complete a standard residential roof replacement in 1-2 days, depending on the square footage and specific material requirements for your home.`
      }
    },
    {
      "@type": "Question",
      "name": `Does Titanium Roofing offer warranties in ${name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Yes. We provide industry-leading labor warranties and manufacturer-backed material warranties for every roof we install in ${name}, giving you peace of mind long after we leave.`
      }
    },
    {
      "@type": "Question",
      "name": `What makes Titanium Roofing different from other roofers in ${name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Unlike storm chasers who leave town, we are your local ${name} roofing neighbors. We focus on transparent, no-pressure inspections and honest advice—if your roof has years of life left, we’ll be the first to tell you.`
      }
    }
  ]
};
---
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbList)} />
<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
