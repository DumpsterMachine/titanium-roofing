---
interface Props {
  location?: string;
}

const { location } = Astro.props;
const displayTitle = location ? `Titanium Roofing in ${location}` : 'Titanium Roofing.';
---
<section class="bg-black text-white py-20 lg:py-32 px-6">
  <div class="max-w-4xl mx-auto text-center flex flex-col items-center">
    <img src="/titanium-logo.jpg" alt="Titanium Roofing Logo" class="max-w-md w-full mb-10 mx-auto" />
    <h1 class="text-5xl font-extrabold tracking-tight sm:text-6xl mb-6">
      Straight Shooting. Honest Inspections.
      <span class="block text-[#E1251B] mt-2">{displayTitle}</span>
    </h1>
    <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
      No storm chasers. No high-pressure sales BS. Just your local {location ? location : 'Riverview/Tampa'} guys providing quality roofs built to last.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#quote" class="bg-[#E1251B] hover:bg-red-700 text-white px-8 py-4 rounded-md font-bold text-lg transition-colors shadow-lg">
        Get a Free, No-BS Quote
      </a>
      <a href="tel:5551234567" class="bg-transparent hover:bg-slate-900 text-white px-8 py-4 rounded-md font-bold text-lg transition-colors ring-2 ring-slate-400">
        Call (555) 123-4567
      </a>
    </div>
  </div>
</section>
