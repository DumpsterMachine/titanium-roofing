---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Guarantees from '../../components/Guarantees.astro';
import Services from '../../components/Services.astro';
import LeadForm from '../../components/LeadForm.astro';
import neighborhoods from '../../titanium_neighborhoods.json';

export async function getStaticPaths() {
  return neighborhoods.map((neighborhood) => {
    // "Town 'n' Country" -> "town-n-country", "San Antonio (FL)" -> "san-antonio-fl"
    const slug = neighborhood.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    return {
      params: { neighborhood: slug },
      props: { name: neighborhood },
    };
  });
}

import SEO from '../../components/SEO.astro';

const { name } = Astro.props;
---

<Layout 
  title={`Titanium Roofing in ${name} | Local Roofers`}
  description={`Looking for the best roofing company in ${name}? Titanium Roofing offers honest inspections and reliable service in ${name}, FL.`}
>
  <SEO name={name} />
  <Hero location={name} />
  <Guarantees />
  <Services />
  <LeadForm />

  <section class="py-16 bg-white border-t border-slate-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-bold mb-4">Why Titanium Roofing in {name}?</h3>
          <p class="text-slate-600 mb-6">
            We know the {name} area. From local zoning requirements to the specific challenges of {name} weather conditions, our team is equipped to handle your roof with precision. We pride ourselves on being your trusted, local roofing partner—not storm chasers.
          </p>
        </div>
        <div>
          <h3 class="text-2xl font-bold mb-4">Serving {name} and Surrounding Communities</h3>
          <p class="text-slate-600 mb-6">Titanium Roofing provides top-tier roofing services across the Tampa Bay region, with a special focus on providing timely, honest assessments for your home in {name}.</p>
        </div>
      </div>
      
      <div class="mt-12 bg-slate-50 p-8 rounded-sm">
        <h3 class="text-2xl font-bold mb-6">Frequently Asked Questions</h3>
        <div class="space-y-6">
          <div>
            <h4 class="font-bold text-slate-900">Do I need a permit for roofing in {name}?</h4>
            <p class="text-slate-600">Yes, most residential roofing projects in {name} require a permit. Titanium Roofing handles the application process for you, ensuring compliance with local {name} building codes.</p>
          </div>
          <div>
            <h4 class="font-bold text-slate-900">How long does a typical roofing project in {name} take?</h4>
            <p class="text-slate-600">While every home in {name} varies, our local crews typically complete a standard residential roof replacement in 1-2 days, depending on the square footage and specific material requirements for your home.</p>
          </div>
          <div>
            <h4 class="font-bold text-slate-900">Does Titanium Roofing offer warranties in {name}?</h4>
            <p class="text-slate-600">Yes. We provide industry-leading labor warranties and manufacturer-backed material warranties for every roof we install in {name}, giving you peace of mind long after we leave.</p>
          </div>
          <div>
            <h4 class="font-bold text-slate-900">What makes Titanium Roofing different from other roofers in {name}?</h4>
            <p class="text-slate-600">Unlike storm chasers who leave town, we are your local {name} roofing neighbors. We focus on transparent, no-pressure inspections and honest advice—if your roof has years of life left, we’ll be the first to tell you.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <footer class="bg-slate-900 text-slate-400 py-12 text-center border-t border-slate-800">
    <div class="max-w-6xl mx-auto px-6">
      <p class="mb-2">&copy; {new Date().getFullYear()} Titanium Roofing. All rights reserved.</p>
      <p class="text-sm">Licensed & Insured in Florida. Serving {name}, Tampa, and surrounding areas.</p>
    </div>
  </footer>
</Layout>
