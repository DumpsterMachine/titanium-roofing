---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Guarantees from '../components/Guarantees.astro';
import Services from '../components/Services.astro';
import LeadForm from '../components/LeadForm.astro';
---

<Layout>
  <Hero />
  <Guarantees />
  <Services />
  <LeadForm />
  
  <section class="py-10 text-center bg-white border-t border-slate-100">
    <a href="/locations" class="text-[#E1251B] font-bold hover:underline">View All Service Areas</a>
  </section>

  <footer class="bg-slate-900 text-slate-400 py-12 text-center border-t border-slate-800">
    <div class="max-w-6xl mx-auto px-6">
      <p class="mb-2">&copy; {new Date().getFullYear()} Titanium Roofing. All rights reserved.</p>
      <p class="text-sm">Licensed & Insured in Florida. Serving Riverview, Tampa, and surrounding areas.</p>
    </div>
  </footer>
</Layout>