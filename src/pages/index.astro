---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Guarantees from '../components/Guarantees.astro';
import Services from '../components/Services.astro';
import LeadForm from '../components/LeadForm.astro';
---

<Layout>
  <Hero />
  
  <section class="py-12 text-center bg-white border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-2xl font-black uppercase text-slate-900 mb-6">Service Areas</h2>
      <a href="/locations" class="inline-block bg-[#E1251B] text-white font-bold py-4 px-8 rounded-sm hover:bg-red-700 transition shadow-lg uppercase tracking-wider">
        View All Roofing Locations
      </a>
    </div>
  </section>

  <Guarantees />
  <Services />
  <Services />
  
  <LeadForm />
  
  <footer class="bg-slate-900 text-slate-400 py-12 text-center border-t border-slate-800">
    <div class="max-w-6xl mx-auto px-6">
      <p class="mb-2">&copy; {new Date().getFullYear()} Titanium Roofing. All rights reserved.</p>
      <p class="text-sm">Licensed & Insured in Florida. Serving Riverview, Tampa, and surrounding areas.</p>
    </div>
  </footer>
</Layout>